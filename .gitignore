# --- ARK Standard Gitignore ---

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ARK Specific (キャッシュと作業場をガード！)

.ark_state.json

# OS files
.DS_Store
Thumbs.db
*.swp

# Environment variables (APIキー漏洩防止！)
.env
.env.local

# Logs
*.log
npm-debug.log*